// FitTrack - Prisma Schema
// Database: PostgreSQL (Supabase)

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// User model - stores user profile and links to all data
model User {
  id             String          @id @default(cuid())
  email          String          @unique
  name           String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  workouts       Workout[]
  foodLogs       FoodLog[]
  nutritionGoals NutritionGoal[]
}

// Workout - one session (e.g. "Leg Day - March 6")
model Workout {
  id        String     @id @default(cuid())
  userId    String
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String // e.g. "Leg Day", "Upper Body"
  date      DateTime
  notes     String?
  createdAt DateTime   @default(now())
  exercises Exercise[]
}

// Exercise - single exercise within a workout (sets, reps, weight)
model Exercise {
  id        String  @id @default(cuid())
  workoutId String
  workout   Workout @relation(fields: [workoutId], references: [id], onDelete: Cascade)
  name      String // e.g. "Bench Press", "Squat"
  sets      Int
  reps      Int
  weight    Float // in kg
  notes     String?
}

// Food log - one food entry per day
model FoodLog {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  foodName  String
  quantity  Float // e.g. 200 (grams), 3 (eggs)
  unit      String   @default("g") // g, servings, etc.
  calories  Float // total calories for this entry
  protein   Float // total protein in grams
  date      DateTime
  createdAt DateTime @default(now())
}

// Nutrition goals - user's daily targets (one active per user, or we use latest)
model NutritionGoal {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  dailyCalories Int
  dailyProtein  Float // in grams
  createdAt     DateTime @default(now())
}
